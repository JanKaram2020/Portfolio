    "@unocss/reset": "0.58.9",
    "canvas": "^3.2.3",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "js-cookie": "^3.0.5",
    "mdx-mermaid": "2.0.3",
    "mermaid": "^11.14.0",
    "next": "15.5.15",
