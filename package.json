{
  "name": "tony-portfolio-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:next": "next dev",
    "dev:uno": "unocss '*/**/*.tsx' '*/**/*.mdx' --minify --out-file=globals.css --watch",
    "dev": "concurrently 'yarn dev:next' 'yarn dev:uno'",
    "start": "next start",
    "lint": "next lint",
    "prebuild": "NODE_ENV=production unocss '*/**/*.tsx' '*/**/*.mdx' --minify --out-file=globals.css",
    "build": "next build",
    "postbuild": "next-sitemap",
    "test": "vitest run",
    "test:watch": "vitest run -w",
    "test:update": "vitest run -u",
    "pre-push": "yarn build"
  },
